entrypoint = "Main.js"
modules = ["nodejs-20", "web", "bash"]
hidden = [".config", "package-lock.json", "package.json" , "config.json.temp", ".lesson", ".git",".gitignore","languages"," utils","includes","DB"]

[nix]
channel = "stable-25_05"

[unitTest]
language = "nodejs"

[deployment]
run = ["node", "Main.js"]
deploymentTarget = "cloudrun"
ignorePorts = false

[[ports]]
localPort = 3000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start ZAO Bot"

[[workflows.workflow]]
name = "Start ZAO Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node Main.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
